---
# This playbook reproduces the {{ tenant }} operations platform from scratch:
#
#   ansible-galaxy collection install -r requirements.yml
#   ./ansible-playbookw platform.yml
#
- name: Provisioning the {{ tenant }} operations platform
  hosts: {{ tenant }}
  become: true
  roles:
    - plexus.platform.base
    - plexus.platform.docker
    - plexus.platform.caddy
    - plexus.platform.deploy
