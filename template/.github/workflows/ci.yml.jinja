{% raw %}name: ci

# Path-aware CI (§ 8.2 PLX). `changes` runs the changed-apps verb and emits a
# JSON matrix; `app` fans the per-app pipeline (check → test → build → deploy)
# over exactly the apps whose sources changed — a docs-only push deploys nothing,
# a shared-package change redeploys its dependents. Managed by copier: edit the
# preset (plexus-ms/preset-repo-web), never this file.

on:
  push:
    branches: [main, develop]
  pull_request:

permissions:
  contents: read
  packages: write

jobs:
  changes:
    uses: plexus-ms/ci-cd/.github/workflows/changes.yml@0.25.0

  app:
    needs: changes
    # Empty matrix is an error, not a no-op — skip the job when nothing changed.
    if: ${{ needs.changes.outputs.apps != '[]' }}
    strategy:
      fail-fast: false
      matrix:
        app: ${{ fromJSON(needs.changes.outputs.apps) }}
    uses: plexus-ms/ci-cd/.github/workflows/pipeline.yml@0.25.0
    with:
      tenant: {% endraw %}{{ tenant }}{% raw %}
      app: ${{ matrix.app }}
      build: ${{ github.event_name == 'push' }}
      deploy: ${{ github.ref == 'refs/heads/main' }}
      host: ${{ vars.DEPLOY_HOST }}
    secrets:
      ssh-key: ${{ secrets.DEPLOY_SSH_KEY }}
{% endraw %}
