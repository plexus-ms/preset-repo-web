plexus_tenant: {{ tenant }}

# Unprivileged user that owns app dirs and runs the deploy verb (via CI SSH).
plexus_deploy_user: plexus
plexus_deploy_root: /opt/stacks

# Attempt to pull + start apps during provisioning. Safe to leave true: a missing
# image (very first bring-up, before CI has pushed) is reported, not fatal.
plexus_up: true

# Apps on this host.
# compose.yml is copied from this monorepo's apps/<name>/ (single
# source of truth); `image` is the last-known-good ref pulled on a restore.
# Add entries as you add apps, e.g.:
#   - name: my-app
#     domain: my-app.example.org
#     image: ghcr.io/{{ github_org }}/my-app:latest
#     port: 3000
plexus_apps: []

# Base packages the host needs
plexus_base_packages:
  - ca-certificates
  - curl
  - gnupg
  - python3-debian # required by deb822_repository module
  - sudo
  - ufw
  - fail2ban
  - unattended-upgrades
  - acl

# Secrets
plexus_deploy_pubkey: "{% raw %}{{ lookup('env', 'DEPLOY_PUBKEY') | default('', true) }}{% endraw %}"
plexus_operator_pubkey: "{% raw %}{{ lookup('env', 'OPERATOR_PUBKEY') | default('', true) }}{% endraw %}"
plexus_ghcr_user: "{% raw %}{{ lookup('env', 'GHCR_USER') | default('', true) }}{% endraw %}"
plexus_ghcr_token: "{% raw %}{{ lookup('env', 'GHCR_TOKEN') | default('', true) }}{% endraw %}"
