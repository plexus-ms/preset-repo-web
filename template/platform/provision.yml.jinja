---
# Base host setup for the {{ tenant }} operations platform — apt repos,
# packages, hardening, container engine, ingress-server install. Rarely
# re-run: fresh hosts and deep-reaching changes only.
#
#   mise platform provision
#
# plexus.platform.alloy (opt-in observability agent) also belongs in this
# phase — append it here if this tenant enables it.
- name: Provision the {{ tenant }} operations platform
  hosts: {{ tenant }}
  become: true
  roles:
    - plexus.platform.base
    - plexus.platform.docker
    - plexus.platform.caddy
